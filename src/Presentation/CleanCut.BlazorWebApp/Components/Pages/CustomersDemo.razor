@inject IJSRuntime JSRuntime
@inject ILogger<CustomersDemo> Logger
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICustomerApiService CustomerApi
<div class="row">
    
    <!-- Get All Customers -->
    <div class="col-lg-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-info text-white">
     <h5 class="mb-0">
     <i class="fas fa-users me-2"></i>GET All Customers
</h5>
     <small>GET /api/customers</small>
   </div>
            <div class="card-body">
      <p class="text-muted">Retrieve all customers in the system</p>
    
                <button class="btn btn-info" @onclick="GetAllCustomers" disabled="@isLoadingAll">
 @if (isLoadingAll)
             {
   <div class="spinner-border spinner-border-sm me-2" role="status"></div>
      }
  <i class="fas fa-download me-1"></i>Load All Customers
            </button>

         @if (!string.IsNullOrEmpty(getAllError))
           {
                 <div class="alert alert-danger mt-3">@getAllError</div>
                }

         @if (allCustomers?.Any() == true)
             {
    <div class="mt-3">
  <h6>Customers Found: @allCustomers.Count</h6>
       <div style="max-height:300px; overflow-y: auto;">
         @foreach (var customer in allCustomers)
{
          <div class="border rounded p-3 mb-2 bg-light">
    <div class="d-flex justify-content-between align-items-start">
        <div>
                  <h6 class="mb-1">@customer.FullName</h6>
           <p class="mb-1 text-muted">@customer.Email</p>
         <small class="text-muted">
 Created: @customer.CreatedAt.ToString("MMM dd, yyyy")
                  @if (customer.UpdatedAt.HasValue)
      {
       <text> | Updated: @customer.UpdatedAt.Value.ToString("MMM dd, yyyy")</text>
        }
                </small>
    </div>
          <span class="badge @(customer.IsActive ? "bg-success" : "bg-secondary")">
   @(customer.IsActive ? "Active" : "Inactive")
       </span>
                </div>
              </div>
          }
     </div>
        </div>
     }
  </div>
        </div>
 </div>

    <!-- Get Customer By ID -->
    <div class="col-lg-6 mb-4">
    <div class="card h-100">
            <div class="card-header bg-success text-white">
       <h5 class="mb-0">
   <i class="fas fa-user me-2"></i>GET Customer by ID
        </h5>
         <small>GET /api/customers/{id}</small>
            </div>
       <div class="card-body">
         <p class="text-muted">Retrieve a specific customer by their GUID</p>
                
      <div class="mb-3">
    <label class="form-label">Customer ID:</label>
     <input type="text" class="form-control" @bind="customerIdToGet" 
     placeholder="Enter customer GUID" disabled="@isLoadingById">
                </div>

 <button class="btn btn-success" @onclick="GetCustomerById" 
         disabled="@(isLoadingById || string.IsNullOrWhiteSpace(customerIdToGet))">
   @if (isLoadingById)
      {
      <div class="spinner-border spinner-border-sm me-2" role="status"></div>
      }
        <i class="fas fa-search me-1"></i>Get Customer
 </button>

    @if (!string.IsNullOrEmpty(getByIdError))
             {
  <div class="alert alert-danger mt-3">@getByIdError</div>
 }

           @if (foundCustomer != null)
          {
   <div class="mt-3 border rounded p-3 bg-light">
            <div class="d-flex justify-content-between align-items-start mb-2">
             <h6>@foundCustomer.FullName</h6>
             <span class="badge @(foundCustomer.IsActive ? "bg-success" : "bg-secondary")">
       @(foundCustomer.IsActive ? "Active" : "Inactive")
            </span>
    </div>
  <p class="mb-1"><strong>Email:</strong> @foundCustomer.Email</p>
      <p class="mb-1"><strong>First Name:</strong> @foundCustomer.FirstName</p>
    <p class="mb-1"><strong>Last Name:</strong> @foundCustomer.LastName</p>
     <p class="mb-1"><strong>Customer ID:</strong> <code>@foundCustomer.Id</code></p>
          <small class="text-muted">
     Created: @foundCustomer.CreatedAt.ToString("MMM dd, yyyy HH:mm")
       @if (foundCustomer.UpdatedAt.HasValue)
 {
        <text> | Updated: @foundCustomer.UpdatedAt.Value.ToString("MMM dd, yyyy HH:mm")</text>
      }
           </small>
   </div>
  }
            </div>
        </div>
    </div>

    <!-- Create Customer -->
    <div class="col-lg-6 mb-4">
        <div class="card h-100">
      <div class="card-header bg-primary text-white">
   <h5 class="mb-0">
      <i class="fas fa-user-plus me-2"></i>POST Create Customer
        </h5>
                <small>POST /api/customers</small>
            </div>
            <div class="card-body">
            <p class="text-muted">Create a new customer in the system</p>
  
            <div class="mb-3">
              <label class="form-label">First Name:</label>
  <input type="text" class="form-control" @bind="newCustomer.FirstName" 
  placeholder="First name" disabled="@isCreating">
      </div>

    <div class="mb-3">
        <label class="form-label">Last Name:</label>
      <input type="text" class="form-control" @bind="newCustomer.LastName" 
              placeholder="Last name" disabled="@isCreating">
</div>

          <div class="mb-3">
     <label class="form-label">Email:</label>
   <input type="email" class="form-control" @bind="newCustomer.Email" 
placeholder="customer@example.com" disabled="@isCreating">
            </div>

          <button class="btn btn-primary" @onclick="CreateCustomer" 
   disabled="@(isCreating || !IsValidCustomer())">
      @if (isCreating)
           {
<div class="spinner-border spinner-border-sm me-2" role="status"></div>
     }
        <i class="fas fa-user-plus me-1"></i>Create Customer
      </button>

         @if (!string.IsNullOrEmpty(createError))
    {
       <div class="alert alert-danger mt-3">@createError</div>
      }

        @if (createdCustomer != null)
       {
      <div class="alert alert-success mt-3">
          <strong>Customer Created Successfully!</strong>
    <div>
           <strong>ID:</strong> @createdCustomer.Id
</div>
         <div>
        <strong>Name:</strong> @createdCustomer.FullName
         </div>
   <div>
        <strong>Email:</strong> @createdCustomer.Email
      </div>
  </div>
           }
     </div>
        </div>
    </div>

    <!-- Update Customer -->
    <div class="col-lg-6 mb-4">
        <div class="card h-100">
       <div class="card-header bg-warning text-dark">
    <h5 class="mb-0">
        <i class="fas fa-user-edit me-2"></i>PUT Update Customer
     </h5>
        <small>PUT /api/customers/{id}</small>
   </div>
  <div class="card-body">
<p class="text-muted">Update an existing customer's information</p>
             
      <div class="mb-3">
<label class="form-label">Customer ID to Update:</label>
    <div class="input-group">
        <input type="text" class="form-control" @bind="updateCustomer.Id" 
        placeholder="Enter customer GUID" disabled="@isUpdating">
        <button class="btn btn-outline-secondary" type="button" @onclick="LoadCustomerForUpdate" 
 disabled="@(isUpdating || string.IsNullOrWhiteSpace(updateCustomer.Id))">
            <i class="fas fa-download"></i>
       </button>
    </div>
      </div>

       <div class="mb-3">
   <label class="form-label">First Name:</label>
        <input type="text" class="form-control" @bind="updateCustomer.FirstName" 
            placeholder="First name" disabled="@isUpdating">
                </div>

      <div class="mb-3">
<label class="form-label">Last Name:</label>
      <input type="text" class="form-control" @bind="updateCustomer.LastName" 
          placeholder="Last name" disabled="@isUpdating">
  </div>

            <div class="mb-3">
               <label class="form-label">Email:</label>
         <input type="email" class="form-control" @bind="updateCustomer.Email" 
 placeholder="customer@example.com" disabled="@isUpdating">
</div>

  <button class="btn btn-warning" @onclick="UpdateCustomer" 
     disabled="@(isUpdating || !IsValidUpdateCustomer())">
           @if (isUpdating)
         {
         <div class="spinner-border spinner-border-sm me-2" role="status"></div>
             }
     <i class="fas fa-save me-1"></i>Update Customer
      </button>

              @if (!string.IsNullOrEmpty(updateError))
                {
        <div class="alert alert-danger mt-3">@updateError</div>
       }

    @if (updatedCustomer != null)
      {
  <div class="alert alert-success mt-3">
         <strong>Customer Updated Successfully!</strong>
           <div>
     <strong>Name:</strong> @updatedCustomer.FullName
  </div>
       <div>
              <strong>Email:</strong> @updatedCustomer.Email
        </div>
            </div>
   }
         </div>
        </div>
    </div>

</div>

@code {
    // State variables
    private bool isLoadingAll = false;
    private bool isLoadingById = false;
    private bool isCreating = false;
 private bool isUpdating = false;

    // Data
    private List<CustomerInfo>? allCustomers;
    private CustomerInfo? foundCustomer;
    private CustomerInfo? createdCustomer;
    private CustomerInfo? updatedCustomer;

    // Form inputs
    private string customerIdToGet = "11111111-1111-1111-1111-111111111111";
    private CreateCustomerRequest newCustomer = new();
    private UpdateCustomerRequest updateCustomer = new();

    // Error messages
    private string getAllError = string.Empty;
    private string getByIdError = string.Empty;
    private string createError = string.Empty;
    private string updateError = string.Empty;

    private async Task GetAllCustomers()
    {
        isLoadingAll = true;
        getAllError = string.Empty;
        allCustomers = null;
        StateHasChanged();

try
        {

            var customers = await CustomerApi.GetAllCustomersAsync();

      if (customers != null)
            {
      allCustomers = customers;
            }
            else
      {
              getAllError = $"API Error: ";
  }
        }
        catch (Exception ex)
        {
            getAllError = $"Error: {ex.Message}";
        }
        finally
 {
      isLoadingAll = false;
         StateHasChanged();
        }
    }

    private async Task GetCustomerById()
    {
        isLoadingById = true;
   getByIdError = string.Empty;
   foundCustomer = null;
   StateHasChanged();

   try
        {

            var customer = await CustomerApi.GetCustomerByIdAsync(Guid.Parse(customerIdToGet));

            if (customer != null)
            {
    foundCustomer = customer;
            }
 else
    {
         getByIdError = $"API Error: ";
     }
        }
        catch (Exception ex)
   {
   getByIdError = $"Error: {ex.Message}";
        }
        finally
        {
            isLoadingById = false;
 StateHasChanged();
}
    }

    private async Task CreateCustomer()
    {
        isCreating = true;
  createError = string.Empty;
        createdCustomer = null;
        StateHasChanged();

        try
        {
      var customer = await CustomerApi.CreateCustomerAsync(newCustomer);

    if (customer != null)
            {
  createdCustomer = customer;
      newCustomer = new(); // Reset form
            }
            else
            {
        createError = $"API Error: ";
          }
        }
        catch (Exception ex)
        {
      createError = $"Error: {ex.Message}";
   }
        finally
  {
     isCreating = false;
      StateHasChanged();
        }
    }

 private async Task LoadCustomerForUpdate()
    {
     try
  {
        
        var customer = await CustomerApi.GetCustomerByIdAsync(Guid.Parse(updateCustomer.Id));

      if (customer != null)
    {
          
   
    updateCustomer.FirstName = customer.FirstName;
         updateCustomer.LastName = customer.LastName;
     updateCustomer.Email = customer.Email;
     StateHasChanged();
  
            }
        }
        catch (Exception ex)
      {
            updateError = $"Error loading customer: {ex.Message}";
      }
    }

  private async Task UpdateCustomer()
    {
  isUpdating = true;
        updateError = string.Empty;
        updatedCustomer = null;
      StateHasChanged();

        try
        {
            if (!Guid.TryParse(updateCustomer.Id, out var customerId))
       {
       updateError = "Invalid Customer ID format.";
     return;
    }

            var customer = await CustomerApi.UpdateCustomerAsync(customerId, updateCustomer);

   if (customer != null)
            {
 updatedCustomer = customer;
     }
       else
{
            updateError = "API Error: Customer not updated.";
      }
      }
        catch (Exception ex)
        {
       updateError = $"Error: {ex.Message}";
        }
   finally
        {
     isUpdating = false;
            StateHasChanged();
        }
    }

    private bool IsValidCustomer()
    {
        return !string.IsNullOrWhiteSpace(newCustomer.FirstName) &&
        !string.IsNullOrWhiteSpace(newCustomer.LastName) &&
          !string.IsNullOrWhiteSpace(newCustomer.Email) &&
   newCustomer.Email.Contains("@");
    }

    private bool IsValidUpdateCustomer()
    {
        return !string.IsNullOrWhiteSpace(updateCustomer.Id) &&
             !string.IsNullOrWhiteSpace(updateCustomer.FirstName) &&
               !string.IsNullOrWhiteSpace(updateCustomer.LastName) &&
     !string.IsNullOrWhiteSpace(updateCustomer.Email) &&
               updateCustomer.Email.Contains("@");
    }

  }